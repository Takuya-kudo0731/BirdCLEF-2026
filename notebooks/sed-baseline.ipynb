    "# PREPROCESSING: OGG -> npy cache\n",
    "df_pre = pd.read_csv(cfg.train_csv).dropna(subset=['primary_label']).reset_index(drop=True)\n",
    "filenames = sorted(df_pre['filename'].unique())\n",
    "print(f'Preprocessing {len(filenames)} audio files -> npy cache')\n",
    "\n",
    "t0 = time.time()\n",
    "skipped = 0\n",
    "for i, fname in enumerate(filenames):\n",
    "    src = os.path.join(cfg.train_audio, fname)\n",
    "    dst = os.path.join(CACHE_DIR, fname.replace('.ogg', '.npy'))\n",
    "    if os.path.exists(dst):\n",
    "        skipped += 1\n",
    "        continue\n",
    "    os.makedirs(os.path.dirname(dst), exist_ok=True)\n",
    "    try:\n",
    "        wf, _ = librosa.load(src, sr=cfg.sr, mono=True)\n",
    "    except Exception:\n",
    "        wf = np.zeros(cfg.chunk_samples, dtype=np.float32)\n",
    "    max_len = cfg.sr * 15\n",
    "    if len(wf) > max_len:\n",
    "        wf = wf[:max_len]\n",
    "    np.save(dst, wf.astype(np.float16))\n",
    "    if (i + 1) % 2000 == 0 or (i + 1) == len(filenames):\n",
    "        elapsed = time.time() - t0\n",
    "        done = i + 1 - skipped\n",
    "        speed = done / elapsed if elapsed > 0 else 1\n",
    "        eta = (len(filenames) - i - 1) / speed\n",
    "        print(f'  [{i+1}/{len(filenames)}] {elapsed/60:.1f}m, {speed:.1f} files/s, ETA {eta/60:.0f}m', flush=True)\n",
    "\n",
    "print(f'Preprocessing done: {(time.time()-t0)/60:.1f} min')"
   ]
